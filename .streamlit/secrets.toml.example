# -----------------------------------------------------------------------------
# Google Sheets persistence — credentials template
# -----------------------------------------------------------------------------
# This is an EXAMPLE. Do one of the following:
#   • Local dev:  copy this file to ".streamlit/secrets.toml" and fill it in.
#                 (secrets.toml is gitignored — never commit real keys.)
#   • Streamlit Cloud:  paste the filled-in version into
#                 App  →  Settings  →  Secrets.
#
# If this section is absent, the app falls back to a local ooo_data.csv,
# which works on your laptop but does NOT persist on Streamlit Cloud.
# -----------------------------------------------------------------------------

[connections.gsheets]
spreadsheet = "https://docs.google.com/spreadsheets/d/1LCpgSL70aSvpUrbyo3jwosQjFwO8k9nMVvkRCGv7ANU/edit?usp=sharing"

